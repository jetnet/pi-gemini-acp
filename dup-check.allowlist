# dup-check.allowlist
# Suppresses known-false-positive duplicate function pairs from similarity-ts.
# Every entry MUST include a reason and date. Re-evaluate quarterly.
#
# Format:
#   pair:<pathA>:<symbolA>||<pathB>:<symbolB>  # reason (YYYY-MM-DD initials)
#   cluster:<glob>                              # reason (YYYY-MM-DD initials)
#
# Pair entries are unordered — pathA||pathB matches pathB||pathA.
# Cluster glob silences an entire cluster when EVERY symbol name matches the glob.
# Lines without a # comment are rejected by the parser.

# Cross-domain structural coincidence — model completions vs citation normalization
pair:src/commands/gemini-model.ts:getGeminiModelCompletions||src/research/citations.ts:normalizeGroundingChunks  # different domains, structural coincidence (2026-05-11 bk)
pair:src/commands/gemini-model.ts:getGeminiModelCompletions||src/research/citations.ts:normalizeRetrievedUrls    # same as above (2026-05-11 bk)

# Same-file citation helpers — different responsibilities within citations.ts
pair:src/research/citations.ts:normalizeGroundingChunks||src/research/citations.ts:normalizeRetrievedUrls  # same file, different citation types (2026-05-11 bk)

# Different domains — citation marker insertion vs error code formatter
pair:src/research/citations.ts:insertProviderCitationMarkers||src/search/run.ts:structuredErrorCode  # different domains (2026-05-11 bk)

# By-design same-file helpers in search display formatting
cluster:formatSearch*  # by-design same-file display helpers; consolidated via formatToolDisplay factory (2026-05-11 bk)
