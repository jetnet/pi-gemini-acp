{
  "name": "pi-gemini-acp",
  "version": "0.8.0",
  "description": "Gemini ACP prompt, search, and research provider for Pi.",
  "repository": "https://github.com/brandonkramer/pi-gemini-acp",
  "keywords": [
    "pi-package",
    "pi-extension",
    "gemini",
    "acp",
    "web-search",
    "research"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/__tests__/**",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:tools": "vitest run src/tools/__tests__/tools-smoke.test.ts --reporter=verbose",
    "smoke:gemini-acp": "vitest run src/acp/__tests__/gemini-acp-smoke.test.ts --reporter=verbose",
    "bench:gemini-search": "node scripts/bench.mjs",
    "audit:strict": "npm audit --omit=dev --audit-level=high",
    "lint:workflows": "github-actionlint .github/workflows/*.yml",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "latest",
    "@mariozechner/pi-tui": "latest",
    "@types/node": "latest",
    "github-actionlint": "^1.7.12",
    "typescript": "latest",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.18.0",
    "pi": ">=0.65.0"
  },
  "dependencies": {
    "sqlite-vec": "0.1.9"
  }
}
