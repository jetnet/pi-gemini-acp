{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"options": {
		"typeAware": true
	},
	"plugins": ["typescript", "unicorn", "promise", "import", "node"],
	"categories": {
		"correctness": "error",
		"suspicious": "error",
		"perf": "error",
		"pedantic": "warn",
		"style": "off",
		"restriction": "off",
		"nursery": "off"
	},
	"env": {
		"node": true,
		"es2024": true
	},
	"rules": {
		"no-console": "off",
		"no-await-in-loop": "off",
		"no-underscore-dangle": "off",
		"no-unneeded-ternary": "error",
		"no-self-compare": "error",
		"require-await": "off",
		"max-lines": "off",
		"max-lines-per-function": "off",
		"max-classes-per-file": "off",
		"no-negated-condition": "off",
		"typescript/require-await": "off",
		"typescript/no-explicit-any": "error",
		"typescript/no-unused-vars": "error",
		"typescript/consistent-type-imports": [
			"warn",
			{ "prefer": "type-imports", "fixStyle": "inline-type-imports" }
		],
		"typescript/consistent-type-exports": "error",
		"typescript/prefer-optional-chain": "warn",
		"typescript/prefer-nullish-coalescing": "warn",
		"typescript/switch-exhaustiveness-check": "error",
		"typescript/no-floating-promises": "error",
		"typescript/no-misused-promises": "error",
		"typescript/no-deprecated": "error",
		"typescript/no-base-to-string": "error",
		"typescript/unbound-method": "error",
		"typescript/no-unnecessary-type-assertion": "error",
		"typescript/no-unnecessary-type-parameters": "warn",
		"typescript/return-await": ["error", "always"],
		"typescript/strict-void-return": "warn",
		"typescript/no-confusing-void-expression": [
			"warn",
			{ "ignoreArrowShorthand": true, "ignoreVoidOperator": true }
		],
		"typescript/restrict-template-expressions": [
			"warn",
			{
				"allowNumber": true,
				"allowBoolean": true,
				"allowNullish": false,
				"allowAny": false
			}
		],
		"typescript/prefer-readonly-parameter-types": "off",
		"typescript/strict-boolean-expressions": "off",
		"typescript/no-unsafe-type-assertion": "off",
		"typescript/no-unsafe-assignment": "off",
		"typescript/no-unsafe-member-access": "off",
		"typescript/no-unsafe-argument": "off",
		"typescript/no-unsafe-call": "off",
		"typescript/no-unsafe-return": "off",
		"typescript/no-unnecessary-type-arguments": "off",
		"typescript/consistent-return": "off",
		"typescript/no-redundant-type-constituents": "off",
		"typescript/no-misused-spread": "off",
		"typescript/no-meaningless-void-operator": "off",
		"unicorn/no-array-sort": "warn",
		"unicorn/no-array-callback-reference": "warn",
		"unicorn/no-useless-undefined": "off",
		"unicorn/no-empty-file": "error",
		"unicorn/no-negated-condition": "off",
		"unicorn/no-null": "off",
		"unicorn/no-lonely-if": "error",
		"unicorn/prefer-module": "off",
		"unicorn/prefer-top-level-await": "off",
		"unicorn/prefer-native-coercion-functions": "error",
		"unicorn/prefer-string-replace-all": "error",
		"unicorn/no-process-exit": "off",
		"unicorn/filename-case": "off",
		"unicorn/prefer-event-target": "off",
		"import/no-cycle": "error",
		"import/no-commonjs": "error",
		"import/no-self-import": "error",
		"import/no-duplicates": "error",
		"import/no-default-export": "off",
		"import/max-dependencies": "off",
		"oxc/no-barrel-file": "error",
		"oxc/no-accumulating-spread": "error",
		"unicorn/prefer-node-protocol": "warn",
		"unicorn/no-await-in-promise-methods": "error",
		"no-else-return": "warn",
		"promise/always-return": "off",
		"no-restricted-imports": [
			"error",
			{
				"paths": [
					{
						"name": "validator",
						"message": "Use coerceString from src/utils/coerce.ts or write a local validator."
					},
					{
						"name": "is-email",
						"message": "Use coerceString from src/utils/coerce.ts or write a local validator."
					},
					{
						"name": "email-validator",
						"message": "Use coerceString from src/utils/coerce.ts or write a local validator."
					},
					{
						"name": "axios",
						"message": "Use the global fetch (Node 22+ has it native)."
					},
					{
						"name": "node-fetch",
						"message": "Use the global fetch (Node 22+ has it native)."
					},
					{
						"name": "got",
						"message": "Use the global fetch (Node 22+ has it native)."
					},
					{
						"name": "cross-fetch",
						"message": "Use the global fetch (Node 22+ has it native)."
					},
					{
						"name": "whatwg-fetch",
						"message": "Use the global fetch (Node 22+ has it native)."
					},
					{
						"name": "moment",
						"message": "Use Intl.DateTimeFormat or new Date()."
					},
					{
						"name": "dayjs",
						"message": "Use Intl.DateTimeFormat or new Date()."
					},
					{
						"name": "date-fns",
						"message": "Use Intl.DateTimeFormat or new Date()."
					},
					{
						"name": "luxon",
						"message": "Use Intl.DateTimeFormat or new Date()."
					},
					{
						"name": "lodash",
						"message": "Use native ES methods or a local helper."
					},
					{
						"name": "lodash-es",
						"message": "Use native ES methods or a local helper."
					},
					{
						"name": "underscore",
						"message": "Use native ES methods or a local helper."
					},
					{
						"name": "ramda",
						"message": "Use native ES methods or a local helper."
					},
					{ "name": "uuid", "message": "Use randomUUID from node:crypto." },
					{ "name": "nanoid", "message": "Use randomUUID from node:crypto." },
					{
						"name": "dotenv",
						"message": "Read env vars via src/config/settings.ts."
					}
				]
			}
		]
	},
	"overrides": [
		{
			"files": ["**/*.test.ts", "**/*.spec.ts", "**/__tests__/**"],
			"rules": {
				"typescript/no-explicit-any": "off",
				"typescript/no-non-null-assertion": "off",
				"typescript/no-floating-promises": "off",
				"typescript/no-misused-promises": "off",
				"max-lines-per-function": "off",
				"max-lines": "off",
				"import/max-dependencies": "off",
				"typescript/strict-void-return": "off"
			}
		},
		{
			"files": ["src/index.ts", "src/types.ts"],
			"rules": {
				"oxc/no-barrel-file": "off",
				"import/max-dependencies": "off"
			}
		}
	],
	"ignorePatterns": [
		"node_modules",
		"dist",
		"build",
		"coverage",
		"graphify-out",
		".pi-lens",
		"scripts/bench.mjs"
	]
}
